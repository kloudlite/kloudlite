# Production Environment Variables Template
# Copy this file to .env.production and fill in your values
# Then run: ./scripts/manage-secrets.sh sync

# ============================================
# Azure Deployment
# ============================================
# Get from: az ad sp create-for-rbac --name "github-actions" --role contributor --scopes /subscriptions/{subscription-id}
AZURE_CREDENTIALS='{"clientId":"xxx","clientSecret":"xxx","subscriptionId":"xxx","tenantId":"xxx"}'

# ============================================
# Application URLs
# ============================================
NEXT_PUBLIC_BASE_URL=https://console.kloudlite.io
NEXT_PUBLIC_API_URL=https://api.kloudlite.io

# ============================================
# Authentication
# ============================================
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# ============================================
# GitHub OAuth
# ============================================
# Setup at: https://github.com/settings/developers
# Callback URL: https://console.kloudlite.io/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ============================================
# Google OAuth
# ============================================
# Setup at: https://console.cloud.google.com/apis/credentials
# Redirect URI: https://console.kloudlite.io/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================
# Microsoft Entra (Azure AD) OAuth
# ============================================
# Setup at: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
# Redirect URI: https://console.kloudlite.io/api/auth/callback/azure-ad
MICROSOFT_ENTRA_CLIENT_ID=
MICROSOFT_ENTRA_CLIENT_SECRET=
MICROSOFT_ENTRA_TENANT_ID=

# ============================================
# Supabase
# ============================================
# Get from: https://app.supabase.com/project/<project-id>/settings/api
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# Cloudflare
# ============================================
# API Token: https://dash.cloudflare.com/profile/api-tokens (requires DNS Edit permission)
# Zone ID: Found in domain overview page
# Origin CA Key: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_DNS_DOMAIN=khost.dev
CLOUDFLARE_ORIGIN_CA_KEY=
