# Server Configuration
PORT=8080
ENVIRONMENT=development
LOG_LEVEL=debug

# JWT Configuration
# IMPORTANT: Must be the same secret used by NextAuth frontend (JWT_SECRET)
# This shared secret allows backend to validate NextAuth-generated JWTs
JWT_SECRET=your-shared-jwt-secret-here-min-32-chars

# Token expiry in hours (should match NextAuth session maxAge: 24 hours)
TOKEN_EXPIRY_HOURS=24