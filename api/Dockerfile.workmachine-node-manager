FROM golang:1.24 AS builder

# Copy source code
WORKDIR /workspace
COPY go.mod go.sum ./
RUN go mod download

COPY . .

# Build the workmachine-node-manager binary
RUN CGO_ENABLED=0 GOOS=linux go build -a -installsuffix cgo -o workmachine-node-manager ./cmd/workmachine-node-manager

# Final image
FROM debian:bookworm-slim

# Install dependencies including nix
RUN apt-get update && apt-get install -y \
    curl \
    xz-utils \
    ca-certificates \
    git \
    && rm -rf /var/lib/apt/lists/*

# Create /nix directory for Nix installation
RUN mkdir -m 0755 /nix && chown root /nix

# Create nixbld group and build users
RUN groupadd -g 30000 nixbld && \
    for i in $(seq 1 10); do \
        useradd -c "Nix build user $i" -d /var/empty -g nixbld -G nixbld -M -N -r -s "$(command -v nologin)" "nixbld$i"; \
    done

# Install Nix in single-user mode
RUN curl -L https://nixos.org/nix/install | sh -s -- --no-daemon

# Source nix profile
ENV PATH="/root/.nix-profile/bin:${PATH}"

# Copy the workmachine-node-manager binary
COPY --from=builder /workspace/workmachine-node-manager /usr/local/bin/workmachine-node-manager

# Run workmachine-node-manager
CMD ["/usr/local/bin/workmachine-node-manager"]
