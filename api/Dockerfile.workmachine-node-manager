# CI Dockerfile - expects pre-built binary at ./bin/workmachine-node-manager
FROM debian:bookworm-slim

# Install dependencies including nix with apt cache mount
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
  --mount=type=cache,target=/var/lib/apt,sharing=locked \
  apt-get update && apt-get install -y \
  curl \
  xz-utils \
  ca-certificates \
  git \
  btrfs-progs \
  && rm -rf /var/lib/apt/lists/*

# Install oras for OCI registry operations (snapshot push)
RUN curl -sL "https://github.com/oras-project/oras/releases/download/v1.2.0/oras_1.2.0_linux_amd64.tar.gz" | \
  tar -xzf - -C /usr/local/bin oras

# Create /nix directory for Nix installation
RUN mkdir -m 0755 /nix && chown root /nix

# Create nixbld group and build users
RUN groupadd -g 30000 nixbld && \
  for i in $(seq 1 10); do \
  useradd -c "Nix build user $i" -d /var/empty -g nixbld -G nixbld -M -N -r -s "$(command -v nologin)" "nixbld$i"; \
  done

# Install Nix in single-user mode with cache mount for downloads
RUN --mount=type=cache,target=/tmp/nix-install-cache \
  curl -L https://nixos.org/nix/install | sh -s -- --no-daemon

# Source nix profile
ENV PATH="/root/.nix-profile/bin:${PATH}"

# Copy the pre-built binary from local filesystem
COPY ./bin/workmachine-node-manager /usr/local/bin/workmachine-node-manager

# Run workmachine-node-manager
CMD ["/usr/local/bin/workmachine-node-manager"]
