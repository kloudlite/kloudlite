# Backend API URL - Used by Next.js to communicate with backend services
NEXT_PUBLIC_API_URL=http://localhost:8080

# Web URL - This is the public-facing URL of the Next.js application
# Used in connection tokens for VS Code extension to connect to the correct server
NEXT_PUBLIC_WEB_URL=http://localhost:3000

# Backend URL - defaults to 127.0.0.1:3001
# All backend services (auth, accounts, etc.) are exposed on the same endpoint
BACKEND_URL=127.0.0.1:3001

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here

# Supabase Configuration — Main (operational) database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# Supabase PII Database — Separate database for personally identifiable information
# Stores: users, magic_link_tokens, contact_messages
PII_SUPABASE_URL=https://your-pii-project.supabase.co
PII_SUPABASE_KEY=your-pii-supabase-service-role-key

# Cloudflare Configuration
# For DNS Management (A records for installations and workmachines)
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ZONE_ID=your-cloudflare-zone-id
CLOUDFLARE_DNS_DOMAIN=khost.dev

# SendGrid Configuration
# For magic link email delivery
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@kloudlite.io
SENDGRID_FROM_NAME=Kloudlite

# Cloudflare Turnstile Captcha Configuration
# For bot protection on magic link form
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# Console URL for magic link generation
NEXT_PUBLIC_CONSOLE_URL=http://localhost:3002

# App URL — used for Stripe checkout success/cancel redirects
NEXT_PUBLIC_APP_URL=http://localhost:3002

# Stripe Configuration
# For subscription billing and payment processing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Kloudlite Cloud (Managed OCI) Configuration
KLOUDLITE_OCI_TENANCY=ocid1.tenancy.oc1..example
KLOUDLITE_OCI_USER=ocid1.user.oc1..example
KLOUDLITE_OCI_REGION=us-ashburn-1
KLOUDLITE_OCI_COMPARTMENT=
KLOUDLITE_OCI_FINGERPRINT=aa:bb:cc:dd:ee:ff
KLOUDLITE_OCI_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# Azure Container Apps (for OCI installer job)
AZURE_SUBSCRIPTION_ID=your-azure-subscription-id
AZURE_RESOURCE_GROUP=rg-kloudlite
OCI_INSTALLER_JOB_NAME=job-oci-installer