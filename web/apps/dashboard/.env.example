# API URL - kubectl proxy sidecar
NEXT_PUBLIC_API_URL=http://localhost:8080

# Web URL - Dashboard runs on port 3001
NEXT_PUBLIC_WEB_URL=http://localhost:3001

# Environment identifier
NEXT_PUBLIC_ENV=development

# Authentication (NextAuth.js)
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars
JWT_SECRET=your-jwt-secret-min-32-chars

# OAuth Providers (configure at least one)
# GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# Domain Configuration
CLOUDFLARE_DNS_DOMAIN=khost.dev
ALLOWED_TENANT_SUBDOMAINS=beanbag
HOSTED_SUBDOMAIN=khost.dev

# Certificate Authority (for VPN/mTLS)
CA_CERT_PEM=
CA_KEY_PEM=
