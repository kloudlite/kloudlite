# Site URL - Public-facing URL for sitemap and robots.txt
# Production: https://kloudlite.io
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cloudflare DNS Domain - Used in middleware for subdomain routing
CLOUDFLARE_DNS_DOMAIN=khost.dev

# Environment - development, staging, or production
NEXT_PUBLIC_ENV=development

# Supabase Configuration - For contact form submissions
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key