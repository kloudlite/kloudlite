{
  "name": "kloudlite-web",
  "private": true,
  "packageManager": "bun@1.1.40",
  "scripts": {
    "dev": "turbo run dev",
    "dev:console": "turbo run dev --filter=console",
    "dev:dashboard": "turbo run dev --filter=dashboard",
    "dev:website": "turbo run dev --filter=website",
    "dev:console-cron": "turbo run dev --filter=console-cron",
    "dev:tests": "turbo run dev --filter=tests",
    "build": "turbo run build",
    "build:console": "turbo run build --filter=console",
    "build:dashboard": "turbo run build --filter=dashboard",
    "build:website": "turbo run build --filter=website",
    "build:tests": "turbo run build --filter=tests",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@types/pg": "^8.18.0",
    "dotenv": "^17.3.1",
    "eslint-config-prettier": "^10.1.8",
    "pg": "^8.19.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "turbo": "^2.3.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "resolutions": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "7.71.1"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "7.71.1"
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.4.0"
  }
}
